{
  "name": "vue-calendar-activity",
  "version": "0.2.0",
  "description": "Modern GitHub-style calendar heatmap for Vue 3. Supports color presets, gradients, custom locales, vertical layout, dark theme and more.",
  "license": "MIT",
  "author": "Artem Zimin",
  "keywords": [
    "vue",
    "vue3",
    "heatmap",
    "calendar",
    "activity",
    "contribution",
    "github",
    "chart",
    "visualization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zema188/vue-calendar-activity.git"
  },
  "homepage": "https://zema188.github.io/vue-calendar-activity/",
  "type": "module",
  "main": "./dist/vue-calendar-activity.cjs.js",
  "module": "./dist/vue-calendar-activity.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-calendar-activity.es.js",
      "require": "./dist/vue-calendar-activity.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
